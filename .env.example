# PostgreSQL (Neon, Supabase, local Docker, etc.) — required for `npm run build` and production.
# Example (Neon): postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Required for “Refresh macro data” on the home page (same value you type in the UI).
MACRO_REFRESH_SECRET="choose-a-long-random-phrase-and-set-the-same-on-vercel"
